{
  "name": "@meow/database",
  "private": true,
  "type": "module",
  "imports": {
    "#database/*": "./src/*",
    "#common/*": "@meow/common/*"
  },
  "exports": {
    "./*": "./src/*"
  },
  "scripts": {
    "db:up": "docker compose -f ./docker-compose.yaml up -d --wait",
    "db:down": "docker compose -f ./docker-compose.yaml down -v",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "bun run src/script/reset.ts",
    "db:seed": "bun run src/script/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@meow/common": "workspace:*",
    "drizzle-orm": "1.0.0-rc.4",
    "postgres": "^3.4.9",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "drizzle-kit": "1.0.0-rc.4",
    "drizzle-seed": "1.0.0-rc.4",
    "vitest": "^4.1.10"
  }
}
